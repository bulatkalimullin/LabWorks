DJANGO_SECRET_KEY=change-me-in-prod
DEBUG=False

POSTGRES_HOST=db
POSTGRES_DB=filecompetition
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# Origins, с которых разрешён доступ к API
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://frontend

# Хосты, по которым можно открывать backend (через nginx/docker)
ALLOWED_HOSTS=localhost,127.0.0.1,api,nginx,api_backend

# Домен для SSL (Let's Encrypt и самоподписанный сертификат). Без хардкода.
SSL_DOMAIN=lab.webflare.ru
# Email для согласия с Let's Encrypt (нужен только для получения сертификата)
LETSENCRYPT_EMAIL=admin@example.com
# Для продакшена добавьте SSL_DOMAIN в ALLOWED_HOSTS и https://SSL_DOMAIN в CORS_ALLOWED_ORIGINS

# S3 / MinIO (опционально)
# AWS_ACCESS_KEY_ID=minio
# AWS_SECRET_ACCESS_KEY=minio12345
# AWS_STORAGE_BUCKET_NAME=filecompetition
# AWS_S3_ENDPOINT_URL=http://minio:9000

